{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "attach",
      "name": "Next.js debug",
      "skipFiles": ["<node_internals>/**"],
      "port": 9229
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Vitest",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceRoot}/node_modules/vitest/vitest.mjs",
      "args": ["--threads", "false", "--reporter", "verbose"],
      "smartStep": true
    }
  ]
}
