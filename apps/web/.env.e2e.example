# E2E test credentials — copy to .env.e2e and fill in real values
# Never commit .env.e2e to version control

# Test user (competitor role)
E2E_USER_EMAIL=competitor@example.com
E2E_USER_PASSWORD=your-password

# Host user (host role in test competition)
E2E_HOST_EMAIL=host@example.com
E2E_HOST_PASSWORD=your-password

# IDs for tests that need specific data
E2E_COMPETITION_ID=your-competition-uuid
E2E_EVENT_ID=your-event-uuid
E2E_PROFILE_ID=your-profile-uuid
E2E_OTHER_PROFILE_ID=another-profile-uuid

# Optional: override base URL (defaults to http://localhost:3000)
# PLAYWRIGHT_BASE_URL=http://localhost:3000
